                <select v-model="searchFilters.roomType" class="w-full px-4 py-3 rounded-xl bg-gray-50 dark:bg-slate-700 border border-gray-300 dark:border-slate-600 focus:border-teal-500 focus:outline-none font-semibold text-gray-800 dark:text-white">
